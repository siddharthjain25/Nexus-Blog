---
import Header from '../components/Header';
import ReadingProgress from '../components/ReadingProgress';
import '../index.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'Nexus Blog', description = 'A minimalist space for thoughts and ideas' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="min-h-dynamic bg-bg-deep selection:bg-primary/30 font-sans overflow-x-hidden w-full">
		<ReadingProgress client:load />
		<Header client:load />
		<main class="min-h-[70vh]">
			<slot />
		</main>
		<footer class="border-t border-border-subtle py-12 mt-20">
			<div class="max-w-5xl mx-auto px-4 text-center">
				<p class="text-slate-500 text-sm italic">
					&copy; {new Date().getFullYear()} Nexus Blog. Built with Astro & FastAPI.
				</p>
			</div>
		</footer>
	</body>
</html>
