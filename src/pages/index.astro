---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { fetchPosts } from "@/utils/api";

const posts = await fetchPosts();
const recentPosts = posts.slice(0, SITE.postPerIndex);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-24 pb-20 flex flex-col items-center text-center relative">
      <!-- Fancy background decorations -->
      <div class="absolute -top-20 -left-20 size-64 bg-accent/10 blur-[120px] rounded-full animate-pulse pointer-events-none"></div>
      <div class="absolute top-40 -right-20 size-80 bg-accent-secondary/10 blur-[150px] rounded-full animate-float pointer-events-none"></div>

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass border-accent/20 text-accent text-sm font-bold mb-8 animate-float shadow-lg shadow-accent/5">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Nexus: Where code meets creativity
      </div>
      
      <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter mb-8 leading-[0.9] text-glow select-none">
        <span class="bg-gradient-to-br from-foreground via-foreground to-accent bg-clip-text text-transparent">Digital</span>
        <br />
        <span class="bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">Alchemy</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-foreground/70 max-w-2xl leading-relaxed mb-12 font-medium">
        Bridging the gap between robust engineering and delightful design.
        Join me on a journey through the architecture of the modern web.
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-6 w-full max-w-md mx-auto relative z-10">
        <LinkButton href="/posts" class="btn-primary w-full sm:w-auto text-center">
          Explore Posts
        </LinkButton>
        <a
          target="_blank"
          href="/rss.xml"
          class="btn-secondary w-full sm:w-auto flex items-center justify-center gap-2"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss class="size-5 stroke-current stroke-2" />
          RSS Feed
        </a>
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="py-20 border-t border-border/30">
          <div class="flex items-end justify-between mb-12 px-2">
            <div>
              <h2 class="text-4xl font-black tracking-tight mb-3">Recent Insights</h2>
              <div class="h-1.5 w-24 bg-gradient-to-r from-accent to-accent-secondary rounded-full"></div>
            </div>
            <LinkButton href="/posts/" class="group px-4 py-2 rounded-xl glass border-accent/10 text-accent hover:text-accent-secondary flex items-center gap-2 font-bold transition-all duration-300">
              The archive
              <IconArrowRight class="size-5 transition-transform group-hover:translate-x-1" />
            </LinkButton>
          </div>
          
          <ul class="grid gap-8">
            {recentPosts.map((data: any) => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>