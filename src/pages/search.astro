---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
import { BACKEND_URL } from "astro:env/client";
---

<Layout title={`Search | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Search" pageDesc="Search any article ...">
    <div class="search-container mt-8">
      <!-- Loading Bar -->
      <div id="search-progress" class="fixed top-0 left-0 h-1 bg-accent transition-all duration-300 ease-out opacity-0 z-50 pointer-events-none" style="width: 0%"></div>
      
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="Search articles..."
          class="w-full bg-background border border-border rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-accent"
          autocomplete="off"
        />
        <div id="search-loading" class="hidden absolute right-3 top-2.5">
           <svg class="animate-spin h-5 w-5 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
           </svg>
        </div>
      </div>

      <div id="search-results" class="mt-8 space-y-6">
        <!-- Results will be injected here -->
      </div>

      <div id="no-results" class="hidden mt-8 text-center text-foreground opacity-70">
        No results found for "<span id="query-string" class="font-bold text-accent"></span>"
      </div>
    </div>
  </Main>
  <Footer />
</Layout>

<script is:inline define:vars={{ BACKEND_URL }}>
  function initSearch() {
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const searchLoading = document.getElementById('search-loading');
    const searchProgress = document.getElementById('search-progress');
    const noResults = document.getElementById('no-results');
    const queryString = document.getElementById('query-string');

    if (!searchInput) return;

    let debounceTimer;

    async function performSearch(query) {
      if (query.trim().length < 2) {
        searchResults.innerHTML = '';
        noResults.classList.add('hidden');
        return;
      }

      searchLoading.classList.remove('hidden');
      searchProgress.style.width = '70%';
      searchProgress.classList.remove('opacity-0');
      noResults.classList.add('hidden');

      try {
        const url = `${BACKEND_URL}/posts/search?q=${encodeURIComponent(query)}`;
        const response = await fetch(url);
        if (!response.ok) throw new Error(`Search failed`);
        
        const posts = await response.json();
        // Filter drafts just in case
        const publicPosts = posts.filter(p => !p.draft);

        searchProgress.style.width = '100%';
        setTimeout(() => {
          searchProgress.classList.add('opacity-0');
          setTimeout(() => { searchProgress.style.width = '0%'; }, 300);
        }, 200);

        searchLoading.classList.add('hidden');
        searchResults.innerHTML = '';

        if (publicPosts.length === 0) {
          queryString.textContent = query;
          noResults.classList.remove('hidden');
        } else {
          publicPosts.forEach(post => {
            const resultItem = document.createElement('div');
            resultItem.className = 'search-result-item';
            resultItem.innerHTML = `
              <a href="/posts/${post.slug}/" class="block group">
                <h2 class="text-xl font-medium text-accent decoration-dashed underline-offset-4 group-hover:underline">
                  ${post.title}
                </h2>
                <p class="mt-2 text-foreground text-sm line-clamp-2 opacity-80">${post.description}</p>
                <div class="mt-2 text-xs text-foreground opacity-60">
                  ${new Date(post.pubDatetime || post.pubDate).toLocaleDateString()}
                </div>
              </a>
            `;
            searchResults.appendChild(resultItem);
          });
        }

        // Update URL
        const params = new URLSearchParams(window.location.search);
        params.set('q', query);
        window.history.replaceState({}, '', `${window.location.pathname}?${params.toString()}`);

      } catch (error) {
        console.error('Search error:', error);
        searchLoading.classList.add('hidden');
        searchProgress.classList.add('opacity-0');
      }
    }

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => performSearch(query), 300);
    });

    // Initial search if query param exists
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q');
    if (query) {
      searchInput.value = query;
      performSearch(query);
    }
  }

  document.addEventListener('astro:page-load', initSearch);
</script>

<style>
  @reference "../styles/global.css";
  .search-result-item {
    @apply border-b border-border pb-6 last:border-0;
  }
</style>
