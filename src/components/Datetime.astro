---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime?: string | Date | null;
  timezone?: string;
  modDatetime?: string | Date | null;
  author?: string;
};

const {
  pubDatetime = null,
  modDatetime = null,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
  author,
} = Astro.props as Props;

/* ========== Formatted Datetime ========== */
const pub = pubDatetime ?? new Date();
const mod = modDatetime ?? null;
const isModified = mod && dayjs(mod).isAfter(dayjs(pub));

const datetime = dayjs(isModified ? (mod as string | Date) : (pub as string | Date)).tz(
  postTimezone || SITE.timezone
);

const date = datetime.format("D MMM, YYYY"); // e.g., '22 Mar, 2025'
---

<div class:list={["flex flex-wrap items-center gap-x-4 text-foreground/60", className]}>
  <div class="flex items-center gap-x-1.5">
    <IconCalendar
      class:list={[
        "text-accent/70",
        { "size-4": size === "sm" },
        { "size-5": size === "lg" },
      ]}
    />
    <time
      class:list={["font-medium", { "text-xs": size === "sm" }, { "text-base": size === "lg" }]}
      datetime={datetime.toISOString()}>{date}</time
    >
    {
      isModified && (
        <span class:list={["ml-1 text-[10px] uppercase tracking-tighter bg-accent/10 px-1.5 py-0.5 rounded-md font-bold text-accent"]}>
          Updated
        </span>
      )
    }
  </div>

  {
    author && (
      <div class:list={["flex items-center gap-x-1", { "text-xs": size === "sm" }, { "text-base": size === "lg" }]}>
        <span class="opacity-70">by</span>
        <span class="font-bold text-foreground/80">{author}</span>
      </div>
    )
  }
</div>
