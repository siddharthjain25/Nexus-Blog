---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-4 z-40 w-full transition-all duration-300 pointer-events-none"
>
  <nav
    id="nav-wrap"
    class:list={[
      "app-layout",
      "glass rounded-2xl sm:rounded-full py-3 px-6 pointer-events-auto",
      "flex items-center justify-between",
    ]}
  >
    <a
      href="/"
      class="text-xl leading-8 font-black whitespace-nowrap sm:text-2xl hover:text-accent transition-all duration-300 hover:scale-105"
    >
      <span class="bg-gradient-to-r from-accent to-accent-secondary bg-clip-text text-transparent">{SITE.title}</span>
    </a>
    
    <div class="flex items-center gap-4">
      <ul
        id="menu-items"
        class:list={[
          "fixed top-24 right-4 h-auto w-48 glass rounded-2xl flex-col items-center justify-start py-8 gap-4 z-50",
          "sm:static sm:h-auto sm:w-auto sm:bg-transparent sm:backdrop-blur-0 sm:border-none sm:shadow-none sm:flex sm:flex-row sm:py-0 sm:gap-x-2",
          "hidden",
        ]}
      >
        <li>
          <a href="/posts" class:list={[{ "active-nav": isActive("/posts") }, "text-lg font-bold sm:text-sm tracking-wide"]}>
            POSTS
          </a>
        </li>
        <li class="flex items-center justify-center sm:ml-2">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-2 rounded-xl hover:bg-white/5 hover:text-accent transition-all duration-300",
              { "text-accent bg-accent/10": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch class="size-6 sm:size-5" />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
      </ul>

      <button
        id="menu-btn"
        class="focus-outline p-2 sm:hidden hover:bg-white/5 rounded-xl transition-colors"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden size-6" />
        <IconMenuDeep id="menu-icon" class="size-6" />
      </button>
    </div>
  </nav>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>