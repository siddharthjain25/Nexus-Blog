---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout pb-8", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-8",
      "border-t border-border/50",
      "flex flex-col items-center justify-between gap-6 sm:flex-row-reverse",
    ]}
  >
    <div class="glass p-2 rounded-xl">
      <Socials />
    </div>
    <div class="flex flex-col items-center sm:items-start text-sm text-foreground/60">
      <p class="font-medium text-foreground/80">&copy; {currentYear} {SITE.title}. All rights reserved.</p>
    </div>
  </div>
</footer>
