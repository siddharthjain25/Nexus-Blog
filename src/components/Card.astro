---
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";
import getPostDatetime from "@/utils/getPostDatetime";

type Props = {
  variant?: "h2" | "h3";
  id: string;
  data: any;
};

const { variant: Heading = "h2", id, data } = Astro.props;

const { title, description } = data;
const pubDatetime = getPostDatetime(data);
const modDatetime = data.modDatetime ? new Date(data.modDatetime) : null;
---

<li>
  <div class="glass-card p-6 rounded-2xl group">
    <a
      href={`/posts/${id}/`}
      class:list={[
        "inline-block text-xl font-bold text-accent mb-2",
        "transition-all duration-300 group-hover:translate-x-1",
      ]}
    >
      <Heading
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
    </a>
    <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} timezone={data.timezone} author={data.author} />
    <p class="mt-3 text-foreground/80 leading-relaxed">{description}</p>
    
    <div class="mt-4 flex items-center text-accent font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <span>Read post</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </div>
  </div>
</li>