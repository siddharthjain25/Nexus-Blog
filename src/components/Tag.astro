---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/search?q=${tag}`}
    transition:name={tag}
    class:list={[
      "flex items-center gap-1.5 px-3 py-1 rounded-full",
      "glass border-accent/20 text-foreground/80 hover:text-accent hover:border-accent/50",
      "transition-all duration-300",
      { "text-xs font-bold uppercase tracking-wider": size === "sm" },
      { "text-sm font-medium": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "text-accent size-3",
        { "size-3.5": size === "lg" },
        { "size-3": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
